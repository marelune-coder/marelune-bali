---
const { yacht } = Astro.props;
const facilities = (yacht.facilities || "").split(",").map(s => s.trim()).filter(Boolean);
---
<article class="yacht-card" data-reveal>
  <div class="yacht-visual">
    <span class="yacht-badge">{yacht.type}</span>
    <img src={yacht.image || "/uploads/marelune-assets/IMG-20260602-WA0078.jpg"} alt={yacht.name} loading="lazy" />
  </div>
  <div class="yacht-content">
    <span class="eyebrow">{yacht.capacityDay || "Contact for details"}</span>
    <h3>{yacht.name}</h3>
    <p>{yacht.summary}</p>
    <div class="yacht-specs">
      <div class="spec-item">
        <span class="spec-label">Length</span>
        <span class="spec-value">{yacht.specLength || "N/A"}</span>
      </div>
      <div class="spec-item">
        <span class="spec-label">Type</span>
        <span class="spec-value">{yacht.specType || yacht.type}</span>
      </div>
    </div>
    <div class="yacht-pricing-preview">
      <p class="pricing-text">{yacht.pricingNotes || "Contact for pricing"}</p>
    </div>
    <div class="yacht-actions">
      <a href={`/fleet/${yacht.slug}/`} class="button button-dark">View Details</a>
      <a href="/book/" class="button button-outline">Book Now</a>
    </div>
  </div>
</article>
