---
const { yacht } = Astro.props;

// Format pricing - take first route price
const firstPrice = yacht.pricingNotes
  ?.split('|')[0]
  ?.trim()
  ?.split(':')[1]
  ?.trim()
  || null;

// Get engine info
const engine = yacht.specMachine?.split(',')[0]?.trim() || yacht.specType || null;
---
<article class="yacht-card" data-reveal>
  <!-- Image Section -->
  <div class="yacht-card__image">
    <span class="yacht-card__type">{yacht.type}</span>
    <img
      src={yacht.image || "/uploads/marelune-assets/IMG-20260602-WA0078.jpg"}
      alt={yacht.name}
      loading="lazy"
    />
  </div>

  <!-- Content Section -->
  <div class="yacht-card__body">
    <!-- Header -->
    <div class="yacht-card__header">
      <span class="yacht-card__eyebrow">{yacht.tagline || yacht.type}</span>
      <h3 class="yacht-card__title">{yacht.name}</h3>
    </div>

    <!-- Quick Specs -->
    <div class="yacht-card__specs">
      <div class="yacht-card__spec">
        <span class="yacht-card__spec-label">Capacity</span>
        <span class="yacht-card__spec-value">{yacht.capacityDay || "Contact us"}</span>
      </div>
      <div class="yacht-card__spec">
        <span class="yacht-card__spec-label">Length</span>
        <span class="yacht-card__spec-value">{yacht.specLength || "N/A"}</span>
      </div>
      <div class="yacht-card__spec">
        <span class="yacht-card__spec-label">Engine</span>
        <span class="yacht-card__spec-value">{engine}</span>
      </div>
    </div>

    <!-- Description -->
    <p class="yacht-card__desc">{yacht.summary}</p>

    <!-- Pricing -->
    {firstPrice && (
      <div class="yacht-card__pricing">
        <span class="yacht-card__price-label">Starting from</span>
        <span class="yacht-card__price">{firstPrice}</span>
      </div>
    )}

    <!-- Actions -->
    <div class="yacht-card__actions">
      <a href={`/fleet/${yacht.slug}/`} class="yacht-card__btn yacht-card__btn--primary">
        View Details
      </a>
      <a href="/book/" class="yacht-card__btn yacht-card__btn--secondary">
        Book Now
      </a>
    </div>
  </div>
</article>
