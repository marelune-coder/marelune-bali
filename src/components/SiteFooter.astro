---
const { site } = Astro.props;
---
<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <a class="brand footer-brand" href="/">
        <img src={site.logo} alt={site.brand} class="footer-logo">
      </a>
      <p>{site.description}</p>
      <div class="social-row">
        {site.socials.map((social) => (
          <a href={social.href} target="_blank" rel="noreferrer">{social.label}</a>
        ))}
      </div>
    </div>
    <div>
      <h3>Main Links</h3>
      {site.nav.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
      <a href="/book/">Book a Trip</a>
    </div>
    <div>
      <h3>CMS Pages</h3>
      <a href="/journeys/">Journey collection</a>
      <a href="/journal/">Travel journal</a>
      <a href="/book/">Lead form</a>
    </div>
    <div>
      <h3>Contact</h3>
      <a href={`mailto:${site.contact_email}`}>{site.contact_email}</a>
      <a href={`https://wa.me/${site.contact_whatsapp}`}>WhatsApp</a>
      <span>{site.contact_location}</span>
    </div>
  </div>
</footer>
