---
const { site } = Astro.props;
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src={site.logo} alt={site.brand} class="footer-logo" />
      <p>{site.description}</p>
    </div>
    <div class="footer-nav">
      <h4>Navigate</h4>
      <ul>
        {site.nav.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
    <div class="footer-contact">
      <h4>Contact</h4>
      <p>{site.contact_location}</p>
      <p><a href={`mailto:${site.contact_email}`}>{site.contact_email}</a></p>
      <p><a href={`https://wa.me/${site.contact_whatsapp}`}>WhatsApp</a></p>
    </div>
    <div class="footer-social">
      <h4>Follow Us</h4>
      <div class="social-links">
        {site.socials.map((social) => (
          <a href={social.href} target="_blank" rel="noopener">{social.label}</a>
        ))}
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} {site.brand}. All rights reserved.</p>
  </div>
</footer>
