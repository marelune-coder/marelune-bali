---
const { journey } = Astro.props;
---
<article class="journey-showcase" data-reveal>
  <a class="journey-visual" href={`/journeys/${journey.slug}/`}>
    <img src={journey.image} alt={journey.location}>
    <div class="journey-title">
      <span>{journey.location}</span>
      <p>{journey.summary}</p>
    </div>
  </a>
  <div class="journey-meta">
    <div><span>Base price</span><strong>{journey.price}</strong></div>
    <div><span>Duration</span><strong>{journey.duration}</strong></div>
    <a href={`/journeys/${journey.slug}/`}>More Details &rarr;</a>
    <div><span>Ideal for</span><strong>{journey.idealFor}</strong></div>
    <div><span>Transport</span><strong>{journey.transport}</strong></div>
  </div>
</article>
