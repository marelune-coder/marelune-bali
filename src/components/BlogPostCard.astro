---
const { post, featured = false } = Astro.props;
---
<article class={`post-card ${featured ? 'is-featured' : ''}`} data-reveal>
  <a class="post-image" href={`/journal/${post.slug}/`}>
    <img src={post.thumbnail} alt="">
  </a>
  <div>
    <span class="eyebrow">{post.category || "Journal"} / {post.readingTime || ""}</span>
    <h3><a href={`/journal/${post.slug}/`}>{post.title}</a></h3>
    <p>{post.description}</p>
    <span class="post-date">{post.date}</span>
  </div>
</article>
