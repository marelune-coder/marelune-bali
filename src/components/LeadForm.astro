---
const { site, leads, journeys, yachts } = Astro.props;

// Journey options for dropdown
const journeyOptions = journeys.map((journey) => ({ value: journey.slug, label: journey.title }));

// Yacht options for dropdown
const yachtOptions = yachts ? yachts.map((yacht) => ({ value: yacht.slug, label: yacht.name })) : [];
---
<div class="booking-form-wrapper">
  <form class="book-form" data-lead-form data-endpoint={leads.endpoint} data-whatsapp={site.contact_whatsapp} data-success={leads.successMessage} data-fallback={leads.fallbackMessage}>
    <div class="form-row">
      <div class="form-group">
        <label for="name">Full Name <span class="required">*</span></label>
        <input id="name" name="name" type="text" required placeholder="Your full name" />
      </div>

      <div class="form-group">
        <label for="whatsapp">WhatsApp Number <span class="required">*</span></label>
        <input id="whatsapp" name="whatsapp" type="tel" required placeholder="62812xxxxxxx" />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="email">Email Address</label>
        <input id="email" name="email" type="email" placeholder="your@email.com" />
      </div>

      <div class="form-group">
        <label for="date">Preferred Date <span class="required">*</span></label>
        <input id="date" name="date" type="date" required />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="yacht">Preferred Yacht</label>
        <select id="yacht" name="yacht">
          <option value="">Select yacht (optional)</option>
          {yachtOptions.map((item) => <option value={item.value}>{item.label}</option>)}
          <option value="any">Any available yacht</option>
        </select>
      </div>

      <div class="form-group">
        <label for="journey">Journey Route <span class="required">*</span></label>
        <select id="journey" name="journey" required>
          <option value="">Select journey route</option>
          {journeyOptions.map((item) => <option value={item.value}>{item.label}</option>)}
          <option value="custom">Custom / Not sure yet</option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="guest_count">Number of Guests</label>
        <input id="guest_count" name="guest_count" type="number" placeholder="6" min="1" max="50" />
      </div>

      <div class="form-group">
        <label for="occasion">Occasion / Purpose</label>
        <select id="occasion" name="occasion">
          <option value="">Select occasion</option>
          <option value="birthday">Birthday Celebration</option>
          <option value="proposal">Marriage Proposal</option>
          <option value="honeymoon">Honeymoon / Romantic</option>
          <option value="family">Family Trip</option>
          <option value="friends">Friends Gathering</option>
          <option value="corporate">Corporate Event</option>
          <option value="content">Content Creation</option>
          <option value="exploring">Just Exploring</option>
        </select>
      </div>
    </div>

    <div class="form-group full-width">
      <label for="notes">Special Requests / Notes</label>
      <textarea id="notes" name="notes" rows="4" placeholder="Tell us your preferred route, special requests, dietary requirements..."></textarea>
    </div>

    <div class="form-submit">
      <button class="button button-primary" type="submit">{leads.submitLabel}</button>
    </div>

    <p class="form-status" data-form-status></p>
  </form>
</div>
